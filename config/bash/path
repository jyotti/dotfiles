#!/usr/bin/env bash

# coreutils
if [ -d ${HOMEBREW_PREFIX}/opt/coreutils ]; then
  export PATH="${HOMEBREW_PREFIX}/opt/coreutils/libexec/gnubin:$PATH"
  export MANPATH="${HOMEBREW_PREFIX}/opt/coreutils/libexec/gnuman:$MANPATH"
fi

